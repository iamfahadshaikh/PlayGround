#!/usr/bin/env bash
set -euo pipefail

TMPDIR=$(mktemp -d)

# Current snapshot
pip freeze | sort > "$TMPDIR/current.txt"

# Simulate upgrade resolution
pip install --upgrade --dry-run $(cut -d= -f1 "$TMPDIR/current.txt") \
  2>/dev/null | \
  grep "Would install" | \
  sed 's/Would install //' | \
  tr ' ' '\n' | \
  sed '/^$/d' | \
  sort > "$TMPDIR/upgrade_sim.txt" || true

# Normalize upgrade list
> "$TMPDIR/upgrade_clean.txt"
while read -r line; do
    pkg=$(echo "$line" | sed 's/-[0-9].*//' )
    ver=$(echo "$line" | grep -o '[0-9].*')
    echo "$pkg==$ver" >> "$TMPDIR/upgrade_clean.txt"
done < "$TMPDIR/upgrade_sim.txt"

sort -o "$TMPDIR/upgrade_clean.txt" "$TMPDIR/upgrade_clean.txt"

TOTAL=$(wc -l < "$TMPDIR/current.txt")

printf "\n"
printf "%-25s %-15s %-15s %-15s %-15s\n" \
"PACKAGE" "CURRENT" "LATEST" "STATUS" "CHANGE_TYPE"
printf "%-25s %-15s %-15s %-15s %-15s\n" \
"-------------------------" "---------------" "---------------" "---------------" "---------------"

while read -r line; do
    pkg=$(echo "$line" | cut -d= -f1)
    cur=$(echo "$line" | cut -d= -f3)

    new_line=$(grep "^$pkg==" "$TMPDIR/upgrade_clean.txt" || true)

    if [[ -n "$new_line" ]]; then
        new_ver=$(echo "$new_line" | cut -d= -f3)
        if [[ "$cur" != "$new_ver" ]]; then
            printf "%-25s %-15s %-15s %-15s %-15s\n" \
            "$pkg" "$cur" "$new_ver" "UPDATE" "VERSION_CHANGE"
        else
            printf "%-25s %-15s %-15s %-15s %-15s\n" \
            "$pkg" "$cur" "$cur" "OK" "-"
        fi
    else
        printf "%-25s %-15s %-15s %-15s %-15s\n" \
        "$pkg" "$cur" "-" "REMOVED" "NOT_IN_RESOLUTION"
    fi
done < "$TMPDIR/current.txt"

# New packages introduced
while read -r line; do
    pkg=$(echo "$line" | cut -d= -f1)
    if ! grep -q "^$pkg==" "$TMPDIR/current.txt"; then
        new_ver=$(echo "$line" | cut -d= -f3)
        printf "%-25s %-15s %-15s %-15s %-15s\n" \
        "$pkg" "-" "$new_ver" "ADDED" "NEW_DEP"
    fi
done < "$TMPDIR/upgrade_clean.txt"

printf "\nTOTAL PACKAGES: %s\n" "$TOTAL"

rm -rf "$TMPDIR"

