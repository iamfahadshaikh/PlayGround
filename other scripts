#!/usr/bin/env bash

set -e

echo "Updating package metadata..."
sudo apt update -qq

echo
echo "===== APT PACKAGES ====="

apt list --installed 2>/dev/null | tail -n +2 | cut -d/ -f1 | while read -r pkg; do
    installed=$(dpkg -s "$pkg" 2>/dev/null | awk -F': ' '/^Version/ {print $2}')
    candidate=$(apt-cache policy "$pkg" | awk '/Candidate:/ {print $2}')

    if [[ -n "$installed" && -n "$candidate" && "$installed" != "$candidate" && "$candidate" != "(none)" ]]; then
        echo "Package: $pkg"
        echo "Installed: $installed"
        echo "Latest:    $candidate"
        echo
    fi
done


echo
echo "===== PYTHON PACKAGES (pip) ====="

pip list --format=freeze | while IFS== read -r pkg installed; do
    latest=$(pip index versions "$pkg" 2>/dev/null | awk -F': ' '/LATEST/ {print $2}')

    if [[ -n "$latest" && "$installed" != "$latest" ]]; then
        echo "Package: $pkg"
        echo "Installed: $installed"
        echo "Latest:    $latest"
        echo
    fi
done

