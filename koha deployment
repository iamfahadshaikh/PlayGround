azureuser@Ubuntu-Server:/opt/koha-docker$ # 1. Clean up any stuck states
sudo docker compose down -v

# 2. Start the containers
sudo docker compose up -d

# 3. Wait for the Database (Vital on Azure VMs)
echo "Waiting 60 seconds for MariaDB to initialize..."
sleep 60

# 4. Re-apply the Database Privileges
sudo docker exec -it koha-db mariadb -u root -prootpassword -e "GRANT ALL PRIVILEGES ON koha_library.* TO 'koha_library'@'%' IDENTIFIED BY 'strongpassword'; FLUSH PRIVILEGES;"

# 5. The "Azure Security Bypass" (Re-apply because the volume was reset)
# This disables the module Azure fights with and fixes the config
sudo docker exec -it koha a2dismod mpm_itk
sudo docker exec -it koha a2enmod mpm_prefork
sudo docker exec -it koha sed -i '/AssignUserID/d' /etc/apache2/sites-enabled/library.conf

# 6. Fix internal log permissions for the new volume
sudo docker exec -it koha mkdir -p /var/log/koha/library
sudo docker exec -it koha chmod -R 777 /var/log/koha

# 7. Restart the services
sudo docker exec -it koha supervisorctl restart apache2
sudo docker exec -it koha supervisorctl restart plack

# 8. Re-populate the Database (The volume deletion emptied the tables)
sudo docker exec -it koha koha-create --create-db --dbhost db library
